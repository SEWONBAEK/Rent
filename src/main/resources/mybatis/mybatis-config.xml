<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE configuration
	PUBLIC "-//mybatis.org//DTD config 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-config.dtd">

<configuration>
	<settings>
		<setting name="logImpl" value="LOG4J2"/>
		<setting name="mapUnderscoreToCamelCase" value="true"/>
		<!-- 
			테이블의 _컬럼을 카멜케이스 자바변수로 변환 
			create_date -> createDate
		-->
	</settings>
	
	<typeAliases>
		<typeAlias type="com.rent.vaca.user.UserVO" alias="user"/>
		<typeAlias type="com.rent.vaca.user.UserTermsVO" alias="userTerm" />
		<typeAlias type="com.rent.vaca.notice.NoticeVO" alias="notice" />
		<typeAlias type="com.rent.vaca.reserv.ReservVO" alias="reserv" />
		<typeAlias type="com.rent.vaca.acco.AccoVO" alias="acco" />
		<typeAlias type="com.rent.vaca.room.RoomVO" alias="room" />
		<typeAlias type="com.rent.vaca.review.ReviewVO" alias="review" />
		<typeAlias type="com.rent.vaca.review.ReviewPhotoVO" alias="reviewPhoto" />
		<typeAlias type="com.rent.vaca.user.BizVO" alias="biz" />
		<typeAlias type="com.rent.vaca.user.BizTermsVO" alias="bizTerm" />
		<typeAlias type="com.rent.vaca.notice.QuestionAttachVO" alias="attach" />
		<typeAlias type="com.rent.vaca.acco.AccoPhotoVO" alias="accoPhoto" />
	</typeAliases>
</configuration>